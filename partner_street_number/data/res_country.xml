<data>
    <record id="base.nl" model="res.country">
        <field
            name="partner_street_number_regex"
        >(?P&lt;street_name>.*)\s+(?P&lt;street_number>[0-9]+)(\s|-)*(?P&lt;street_number2>.*)$</field>
        <field
            name="partner_street_number_format"
        >{{object.street_name}}{{object.street_number and ' ' or ''}}{{object.street_number}}{{(object.street_number2 or '').isdigit() and '-' or ''}}{{object.street_number2}}</field>
    </record>
</data>
