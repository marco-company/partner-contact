<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='partner_autocomplete']" position="after">
                <div
                    class="col-xs-12 col-md-6 o_setting_box"
                    id="contact_address_default_allow_all_partners"
                >
                    <div class="o_setting_left_pane">
                        <field name="contact_address_default_allow_all_partners" />
                    </div>
                    <div
                        class="o_setting_right_pane"
                        id="contact_address_default_allow_all_partners_setting"
                    >
                        <label for="contact_address_default_allow_all_partners" />
                        <div class="text-muted">
                            If enabled, the default delivery, invoice, and contact addresses are not limited to the partner’s child contacts—you can select any contact.
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
