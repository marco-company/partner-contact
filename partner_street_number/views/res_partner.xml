<data>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <field name="street" position="attributes">
                <attribute
                    name="groups"
                    add="!partner_street_number.group_edit_split_street_name"
                    separator=","
                />
            </field>
            <field name="street" position="after">
                <div
                    class="oe_edit_only o_row"
                    groups="partner_street_number.group_edit_split_street_name"
                >
                    <field
                        name="street_name"
                        placeholder="Street..."
                        class="o_address_street_name"
                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"
                    />
                    <field
                        name="street_number"
                        placeholder="House..."
                        class="o_address_street_number"
                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"
                    />
                    <field
                        name="street_number2"
                        placeholder="Door..."
                        class="o_address_street_number2"
                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"
                    />
                </div>
            </field>
            <xpath
                expr="//field[@name='child_ids']/form//field[@name='street']"
                position="attributes"
            >
                <attribute
                    name="groups"
                    add="!partner_street_number.group_edit_split_street_name"
                    separator=","
                />
            </xpath>
            <xpath
                expr="//field[@name='child_ids']/form//field[@name='street']"
                position="after"
            >
                <div
                    class="oe_edit_only o_row"
                    groups="partner_street_number.group_edit_split_street_name"
                >
                    <field
                        name="street_name"
                        placeholder="Street..."
                        class="o_address_street_name"
                    />
                    <field
                        name="street_number"
                        placeholder="House..."
                        class="o_address_street_number"
                    />
                    <field
                        name="street_number2"
                        placeholder="Door..."
                        class="o_address_street_number2"
                    />
                </div>
            </xpath>
            <sheet position="after">
                <field name="street" invisible="1" />
                <field name="street_name" invisible="1" />
                <field name="street_number" invisible="1" />
                <field name="street_number2" invisible="1" />
            </sheet>
            <xpath expr="//field[@name='child_ids']/form" position="inside">
                <field name="street" invisible="1" />
                <field name="street_name" invisible="1" />
                <field name="street_number" invisible="1" />
                <field name="street_number2" invisible="1" />
            </xpath>
        </field>
    </record>
</data>
